# =============================================================================
# CashTrace Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for local development.
# =============================================================================

# --- General ---
NODE_ENV=development
PORT=4000

# --- Database (PostgreSQL) ---
# Used by Prisma ORM
DATABASE_URL=postgresql://cashtrace:cashtrace@localhost:5433/cashtrace

# Used by pg Pool (raw SQL queries)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cashtrace
DB_USER=cashtrace
DB_PASSWORD=cashtrace
DB_POOL_MAX=20
DB_SSL=false

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-byte-hex-string

# --- Encryption ---
# 32-byte hex key for AES-256 audit log encryption (optional in dev)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUDIT_ENCRYPTION_KEY=
# ENCRYPTION_KEY=

# --- Email ---
# Base URL for magic link and password reset URLs
APP_BASE_URL=http://localhost:3000

# --- AWS S3 (optional for local dev) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_BUCKET=

# --- Google Gemini AI (optional for local dev) ---
# GEMINI_API_KEY=
