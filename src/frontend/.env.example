# =============================================================================
# CashTrace Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local for local development and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# --- Application ---
# The environment name: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# The public URL of this frontend app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- API ---
# Base URL for the CashTrace Express backend API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Feature Flags ---
# Enable PWA install prompt
NEXT_PUBLIC_FEATURE_PWA=false

# Enable offline mode support
NEXT_PUBLIC_FEATURE_OFFLINE=false

# Enable dark mode theme toggle
NEXT_PUBLIC_FEATURE_DARK_MODE=true
